---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SpeciesStats from '../../components/SpeciesStats.astro';
import SectionBlock from '../../components/SectionBlock.astro';
import ThreatGrid from '../../components/ThreatGrid.astro';
import Gallery from '../../components/Gallery.astro';
import Bibliography from '../../components/Bibliography.astro';

export async function getStaticPaths() {
  const entries = await getCollection('felinos');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'felinos'>;
}

const { entry } = Astro.props;
const { data } = entry;

const siteUrl = 'https://felinosdeargentina.org';

const pageUrl = `${siteUrl}/felinos/${data.slug}/`;

const articleJsonLd = {
  '@type': 'Article',
  headline: data.seo.title,
  description: data.seo.description,
  url: pageUrl,
  image: `${siteUrl}${data.hero.image.src}`,
  about: {
    '@type': 'Animal',
    name: data.hero.title,
    alternateName: data.scientific_name,
  },
};

---

<Layout
  title={data.seo.title}
  description={data.seo.description}
  canonicalUrl={pageUrl}
  image={data.hero.image.src}
  type="article"
  jsonLd={[articleJsonLd]}
>
  <!-- Hero -->
  <Hero
    title={data.hero.title}
    subtitle={data.hero.subtitle}
    image={data.hero.image}
    alt={data.hero.alt}
  />

  <!-- Stats bar -->
  {data.stats && (
    <SpeciesStats
      commonName={data.hero.title}
      scientificName={data.scientific_name}
      conservationStatusIucn={data.conservation_status_iucn}
      conservationStatusAr={data.conservation_status_ar}
      stats={data.stats}
    />
  )}

  <!-- Content sections — loop uniforme, el mapa viene del MD via section.map -->
  {data.sections.map((section, i) => (
    <SectionBlock
      id={section.id}
      title={section.title}
      content={section.content}
      images={section.images}
      map={section.map}
      index={i}
    />
  ))}

  <!-- Threats -->
  {data.threats.length > 0 && (
    <div id="amenazas" class="scroll-mt-24">
      <ThreatGrid threats={data.threats} />
    </div>
  )}

  <!-- Gallery -->
  {data.gallery.length > 0 && (
    <Gallery items={data.gallery} title="Galería" speciesName={data.hero.title} />
  )}

  <!-- Bibliography -->
  {data.bibliography && data.bibliography.length > 0 && (
    <Bibliography entries={data.bibliography} />
  )}
</Layout>
