---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PhotographerRow from '../../components/PhotographerRow.astro';

const entries = await getCollection('fotografos');
const fotografos = entries[0]!.data.fotografos.slice().sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));

const felinosEntries = await getCollection('felinos');
const felinosByScientificName = new Map(felinosEntries.map((f) => [f.data.scientific_name.toLowerCase(), f.data.slug]));

const pageUrl = new URL(`/fotografos/`, Astro.site);
---

<Layout
  title="Fotógrafos | Felinos de Argentina"
  description="Fotógrafos que colaboraron con imágenes para Felinos de Argentina."
  canonicalUrl={pageUrl.href}
>
  <section class="bg-base-900 py-20 text-white">
    <div class="mx-auto max-w-7xl px-6">
      <h1
        class="font-display font-bold text-white"
        style="font-size: var(--text-headline); line-height: var(--text-headline--line-height);"
        data-reveal
        data-animation="animate-fade-in-up"
      >
        Fotógrafos
      </h1>
      <p
        class="text-base-400 mt-4 max-w-xl leading-relaxed"
        data-reveal
        data-animation="animate-fade-in-up"
        data-delay="150"
      >
        Agradecemos a los fotógrafos que hicieron posible este proyecto con su trabajo.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-6">
      <ul class="divide-base-100 m-0 list-none divide-y p-0">
        {
          fotografos.map((f, i) => (
            <PhotographerRow
              nombre={f.nombre}
              contacto={f.contacto}
              felinos={f.felinos}
              felinosByScientificName={felinosByScientificName}
            />
          ))
        }
      </ul>
    </div>
  </section>
</Layout>
