---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const entries = await getCollection('fotografos');
const fotografos = entries[0]!.data.fotografos.slice().sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));

const felinosEntries = await getCollection('felinos');
const felinosByScientificName = new Map(felinosEntries.map((f) => [f.data.scientific_name.toLowerCase(), f.data.slug]));

function getSlug(scientificName: string): string | undefined {
  return felinosByScientificName.get(scientificName.toLowerCase());
}

const siteUrl = 'https://felinosdeargentina.org';
const pageUrl = `${siteUrl}/fotografos/`;
---

<Layout
  title="Fotógrafos | Felinos de Argentina"
  description="Fotógrafos que colaboraron con imágenes para Felinos de Argentina."
  canonicalUrl={pageUrl}
>
  <section class="bg-base-900 py-20 text-white">
    <div class="mx-auto max-w-7xl px-6">
      <h1
        class="font-display font-bold text-white"
        style="font-size: var(--text-headline); line-height: var(--text-headline--line-height);"
      >
        Fotógrafos
      </h1>
      <p class="text-base-400 mt-4 max-w-xl leading-relaxed">
        Agradecemos a los fotógrafos que hicieron posible este proyecto con su trabajo.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-6">
      <ul class="divide-base-100 m-0 list-none divide-y p-0">
        {
          fotografos.map((f) => {
            const felinos = (f.felinos ?? []).slice().sort((a, b) => a.localeCompare(b, 'es'));
            return (
              <li class="flex items-center justify-between gap-6 py-5">
                <div class="flex flex-col gap-0.5">
                  <span class="text-base-900 font-medium">{f.nombre}</span>
                  {felinos.length > 0 && (
                    <p class="text-xs tracking-wide text-stone-400">
                      {felinos.map((nombre, i) => {
                        const slug = getSlug(nombre);
                        return (
                          <>
                            {slug ? (
                              <a href={`/felinos/${slug}/`} class="transition-colors hover:text-stone-600">
                                {nombre}
                              </a>
                            ) : (
                              <span>{nombre}</span>
                            )}
                            {i < felinos.length - 1 && ', '}
                          </>
                        );
                      })}
                    </p>
                  )}
                </div>
                <div class="flex flex-wrap justify-end gap-2">
                  {(f.contacto ?? []).map((c) => (
                    <a
                      href={c.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 rounded-full bg-stone-100 px-3 py-1.5 text-xs font-semibold text-stone-600 transition-colors duration-150 hover:bg-stone-200"
                    >
                      {c.titulo}
                      <i class="ph ph-arrow-up-right" aria-hidden="true" />
                    </a>
                  ))}
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</Layout>
