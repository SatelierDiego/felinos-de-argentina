---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';

const librosEntries = await getCollection('libros');
const books = librosEntries[0]!.data.books;
---

<Layout
  title="Libros recomendados | Felinos de Argentina"
  description="Una selección de publicaciones científicas y de divulgación sobre los felinos silvestres de Argentina y América del Sur."
>
  <!-- Header -->
  <section class="bg-stone-900 py-20 text-white">
    <div class="mx-auto max-w-7xl px-6">
      <h1
        class="font-display font-bold text-white"
        style="font-size: var(--text-headline); line-height: var(--text-headline--line-height);"
        data-animate="animate-fade-in-up"
      >
        Libros recomendados
      </h1>
      <p class="mt-4 max-w-xl leading-relaxed text-stone-400" data-animate="animate-fade-in-up" data-delay="150ms">
        Una selección de publicaciones científicas y de divulgación sobre los felinos silvestres de Argentina y América
        del Sur.
      </p>
    </div>
  </section>

  <!-- Books grid -->
  <section class="bg-stone-50 py-20">
    <div class="mx-auto max-w-7xl px-6">
      <ul class="m-0 grid list-none grid-cols-1 gap-8 p-0 md:grid-cols-2">
        {
          books.map((book, i) => (
            <li data-animate="animate-fade-in-up" data-delay={`${i * 60}ms`}>
              <article class="rounded-card shadow-card flex h-full flex-col bg-white ring-1 ring-stone-100 lg:flex-row">
                <figure class="relative flex max-h-52 w-full shrink-0 items-center justify-center overflow-hidden bg-stone-100 p-1 sm:w-48 lg:max-h-full lg:w-44 lg:p-5">
                  <div
                    class="absolute inset-0 scale-110 bg-cover bg-center blur-lg brightness-75"
                    style={`background-image: url(${book.cover.src})`}
                    aria-hidden="true"
                  />
                  <Image
                    src={book.cover}
                    alt={`Portada de ${book.title}`}
                    width={200}
                    height={300}
                    class="relative z-10 mx-auto max-h-full w-full object-contain transition-transform duration-500 hover:scale-105 lg:object-cover"
                    loading="lazy"
                  />
                </figure>

                <div class="flex min-w-0 flex-1 flex-col gap-3 p-5">
                  <div class="flex flex-col gap-1">
                    <h2 class="font-display text-lg leading-snug font-bold text-stone-900">{book.title}</h2>
                    <p class="text-xs tracking-wide text-stone-400 uppercase">
                      {book.authors.join(', ')} · {book.year}
                    </p>
                    <p class="text-xs text-stone-400 italic">{book.editorial}</p>
                  </div>

                  <p class="flex-1 text-sm leading-relaxed text-stone-600">{book.description.trim()}</p>

                  {book.links.length > 0 && (
                    <div class="flex flex-wrap gap-2 pt-1">
                      {book.links.map((link, li) => (
                        <a
                          href={link.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class:list={[
                            'inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-semibold transition-colors duration-150',
                            li === 0
                              ? 'bg-amber-500 text-white hover:bg-amber-600'
                              : 'bg-stone-100 text-stone-600 hover:bg-stone-200',
                          ]}
                        >
                          {link.label}
                          <i class="ph ph-arrow-up-right" aria-hidden="true" />
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>
