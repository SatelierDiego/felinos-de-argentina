---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import BookCard from '@/components/BookCard.astro';
import Hero from '@/components/Hero.astro';

import heroImage from '@/assets/images/books/books-hero.jpg';

const librosEntries = await getCollection('libros');
const books = librosEntries[0]!.data.books;
---

<Layout
  title="Libros recomendados | Felinos de Argentina"
  description="Una selección de publicaciones científicas y de divulgación sobre los felinos silvestres de Argentina."
>
  <Hero
    title="Libros recomendados"
    subtitle="Libros que no pueden faltar en la biblioteca de cualquier amante de los felinos y la naturaleza."
    image={heroImage}
    alt=""
    size="narrow"
  />

  <section class="bg-stone-50 py-20">
    <div class="mx-auto max-w-7xl px-6">
      <ul class="m-0 grid list-none grid-cols-1 gap-8 p-0 md:grid-cols-2">
        {
          books.map((book, i) => (
            <li data-reveal data-animation="animate-fade-in-up" data-delay={i * 60}>
              <BookCard
                title={book.title}
                authors={book.authors}
                editorial={book.editorial}
                year={book.year}
                cover={book.cover}
                description={book.description}
                links={book.links}
              />
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>
