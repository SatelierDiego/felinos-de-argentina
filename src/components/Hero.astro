---
import { Image } from 'astro:assets';
import type { HeroProps } from '../types/components/hero';
import separator from '../assets/separator_0.svg';

interface Props extends HeroProps {}

const { title, subtitle, image, alt, separatorColor = '#111111' } = Astro.props;
---

<section class="relative isolate h-[80vh] min-h-[500px] md:h-[85vh] md:min-h-130 w-full overflow-hidden">
  <!-- Background image - responsive -->
  <Image
    src={image}
    alt={alt}
    widths={[640, 768, 1024, 1280, 1536, 1920]}
    sizes={`(max-width: 640px) 640px, (max-width: 768px) 768px, (max-width: 1024px) 1024px, (max-width: 1280px) 1280px, (max-width: 1536px) 1536px, 1920px`}
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />

  <!-- Content -->
  <div
    class="relative flex h-full items-end px-4 md:px-6 lg:px-8 pb-12 md:pb-16 after:absolute after:inset-0 after:bg-[linear-gradient(to_top_right,rgba(0,0,0,.85)_0%,rgba(0,0,0,0)_60%)] after:content-['']"
  >
    <div class="z-10 mx-auto w-full max-w-7xl">
      <h1
        class="font-display font-bold text-white"
        style="font-size: var(--text-display); line-height: var(--text-display--line-height);"
        data-animate="animate-fade-in-up"
      >
        {title}
      </h1>
      <p
        class="mt-4 max-w-2xl text-lg leading-relaxed text-white/80"
        data-animate="animate-fade-in-up"
        data-delay="150ms"
      >
        {subtitle}
      </p>
      <slot />
    </div>
  </div>

  <!-- Separator SVG -->
  <div
    class="absolute inset-x-0 bottom-0 h-7 w-full bg-bottom"
    style={`background-color: ${separatorColor}; -webkit-mask-image: url(${separator.src}); mask-image: url(${separator.src}); -webkit-mask-size: 100% 100%; mask-size: 100% 100%; -webkit-mask-position: center bottom; mask-position: center bottom; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;`}
    aria-hidden="true"
  >
  </div>
</section>
