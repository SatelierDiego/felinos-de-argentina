---
import { marked } from 'marked';
import type { HighlightBlockProps } from '../types/components/SectionBlock';

import separatorContent from '../assets/separator.svg?raw';

interface Props extends HighlightBlockProps {}

const { id, title, content, separatorBefore = false, separatorAfter = false } = Astro.props;

const htmlContent = marked.parse(content) as string;
---

<section
  id={id}
  class="bg-highlight scroll-mt-24 text-white"
  aria-labelledby={title ? `section-${id}-heading` : undefined}
>
  {
    separatorBefore && (
      <div class="text-highlight w-full overflow-hidden -translate-y-6">
        <div set:html={separatorContent} class="h-auto min-w-[2000px] w-full" />
      </div>
    )
  }

  <div class="mx-auto max-w-7xl px-6 py-8">
    <div class="mx-auto flex max-w-4xl flex-col justify-center" data-reveal data-animation="animate-fade-in-up">
      {
        title && (
          <h2 id={`section-${id}-heading`} class="font-display mb-6 text-3xl font-bold text-white">
            {title}
          </h2>
        )
      }
      <div class="prose-content space-y-0 leading-relaxed" set:html={htmlContent} />
    </div>
  </div>

  {
    separatorAfter && (
      <div class="text-highlight w-full overflow-hidden translate-y-6 rotate-180">
        <div set:html={separatorContent} class="h-auto min-w-[2000px] w-full" />
      </div>
    )
  }
</section>
