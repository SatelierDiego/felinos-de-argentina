---
interface Props {
  entries: string[];
}

const { entries } = Astro.props;
---

<section class="border-t border-base-200 bg-base-50 py-12" aria-labelledby="bibliography-heading">
  <div class="mx-auto max-w-7xl px-6">
    <h2 id="bibliography-heading" class="font-display text-sm font-semibold uppercase tracking-widest text-base-500 mb-6">
      Bibliografía
    </h2>
    <ol class="space-y-3 list-none p-0 m-0">
      {entries.map((entry) => (
        <li class="text-xs text-base-500 leading-relaxed">{entry}</li>
      ))}
    </ol>
  </div>
</section>
