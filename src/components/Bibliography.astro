---
interface Props {
  entries: string[];
}

const { entries } = Astro.props;
---

<section class="border-base-200 bg-base-50 border-t py-12" aria-labelledby="bibliography-heading">
  <div class="mx-auto max-w-7xl px-6">
    <h2
      id="bibliography-heading"
      class="font-display text-base-500 mb-6 text-sm font-semibold tracking-widest uppercase"
    >
      Bibliografía
    </h2>
    <ol class="m-0 list-none space-y-3 p-0">
      {entries.map((entry) => <li class="text-base-500 text-xs leading-relaxed">{entry}</li>)}
    </ol>
  </div>
</section>
