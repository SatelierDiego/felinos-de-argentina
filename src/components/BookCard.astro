---
import { Image } from 'astro:assets';
import type { BookCardProps } from '../types/components/BookCard';

interface Props extends BookCardProps {}

const { title, authors, editorial, year, cover, description, links } = Astro.props;
---

<article
  class="rounded-card shadow-card ring-accent/20 flex h-full flex-col overflow-hidden bg-white ring-1 lg:flex-row"
>
  <figure
    class="relative flex max-h-52 w-full shrink-0 items-center justify-center overflow-hidden bg-white p-1 sm:w-48 lg:max-h-full lg:w-44 lg:p-5"
  >
    <div
      class="absolute inset-0 scale-110 bg-cover bg-center blur-xl brightness-75"
      style={`background-image: url(${cover.src})`}
      aria-hidden="true"
    >
    </div>
    <Image
      src={cover}
      alt={`Portada de ${title}`}
      width={200}
      height={300}
      class="relative z-10 mx-auto max-h-full w-full object-contain ring ring-white/10 transition-transform duration-500 hover:scale-105 lg:object-cover"
      loading="lazy"
    />
  </figure>

  <div class="flex min-w-0 flex-1 flex-col gap-3 p-5">
    <div class="flex flex-col gap-1">
      <h2 class="font-display text-base text-lg leading-snug font-bold">{title}</h2>
      <p class="text-base/60 text-xs tracking-wide uppercase">
        {authors.join(', ')} · {year}
      </p>
      <p class="text-base/60 text-xs italic">{editorial}</p>
    </div>

    <p class="flex-1 text-base/80 text-sm leading-relaxed">{description.trim()}</p>

    {
      /*
      links.length > 0 && (
        <div class="flex flex-wrap gap-2 pt-1">
          {links.map((link, i) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                'inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-semibold transition-colors duration-150',
                i === 0
                  ? 'bg-highlight/80 hover:bg-highlight/90 text-white'
                  : 'text-base/60 bg-accent/10 hover:bg-accent/20',
              ]}
            >
              {link.label}
              <i class="ph ph-arrow-up-right" aria-hidden="true" />
            </a>
          ))}
        </div>
      )
    */
    }
  </div>
</article>
