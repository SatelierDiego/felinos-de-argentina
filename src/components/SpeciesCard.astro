---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  slug: string;
  title: string;
  subtitle: string;
  image: ImageMetadata;
  alt: string;
  scientificName: string;
  conservationStatus: string;
}

const { slug, title, subtitle, image, alt, scientificName, conservationStatus } =
  Astro.props;

const statusColors: Record<string, string> = {
  'En Peligro': 'bg-danger-400/20 text-danger-600',
  'Vulnerable': 'bg-accent-100 text-accent-700',
  'Casi amenazado': 'bg-accent-50 text-accent-600',
  'Preocupación menor': 'bg-brand-100 text-brand-700',
};
const statusClass =
  statusColors[conservationStatus] ?? 'bg-base-100 text-base-700';
---

<article class="group relative flex flex-col overflow-hidden rounded bg-white shadow-sm ring-1 ring-base-100 transition-shadow hover:shadow-lg">
  <!-- Image -->
  <a href={`/felinos/${slug}/`} class="block overflow-hidden aspect-[3/2]" tabindex="-1" aria-hidden="true">
    <Image
      src={image}
      alt={alt}
      width={600}
      height={400}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
  </a>

  <!-- Body -->
  <div class="flex flex-1 flex-col gap-3 p-6">
    <!-- Status badge -->
    <span class:list={['inline-flex w-fit items-center rounded-full px-2.5 py-0.5 text-xs font-medium', statusClass]}>
      {conservationStatus}
    </span>

    <div>
      <h2 class="font-display text-xl font-bold text-base-900 leading-snug">
        <a href={`/felinos/${slug}/`} class="hover:text-accent-700 transition-colors">
          {title}
        </a>
      </h2>
      <p class="mt-0.5 text-xs italic text-base-400">{scientificName}</p>
    </div>

    <p class="text-sm text-base-600 leading-relaxed line-clamp-3">{subtitle}</p>

    <a
      href={`/felinos/${slug}/`}
      class="mt-auto inline-flex items-center gap-1.5 text-sm font-medium text-accent-600 hover:text-accent-800 transition-colors"
    >
      Leer más
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</article>
