---
import type { ImageMetadata } from 'astro';
import ImageBlock from './ImageBlock.astro';
import LeafletMap from './LeafletMap.astro';
import type { SectionBlockProps } from '../types/components/SectionBlock';

import separatorContent from '../assets/separator.svg?raw';

interface Props extends SectionBlockProps {}

const {
  id,
  title,
  content,
  images = [],
  map,
  index = 0,
  highlight = false,
  separatorBefore = false,
  separatorAfter = false,
} = Astro.props;
const imagesRight = index % 2 === 0;
const hasImages = images.length > 0;
const hasRightCol = hasImages || !!map;

// Convert plain text with *italic* to simple HTML
const htmlContent = content
  .replace(/\*([^*]+)\*/g, '<em>$1</em>')
  .split('\n\n')
  .filter(Boolean)
  .map((p: string) => `<p>${p.trim()}</p>`)
  .join('');
---

<section
  id={id}
  class:list={['scroll-mt-24', highlight ? 'bg-highlight text-white' : 'bg-background text-base']}
  aria-labelledby={title ? `section-${id}-heading` : undefined}
>
  {
    separatorBefore && (
      <div class='w-full -translate-y-6 text-highlight'>
        <div set:html={separatorContent} class="h-auto w-full" />
      </div>
    )
  }

  <div class:list={['mx-auto max-w-7xl px-6', highlight ? 'py-8' : 'py-24']}>
    <div
      class:list={[
        'grid items-start gap-12',
        hasRightCol ? 'grid-cols-1 lg:grid-cols-2' : 'grid-cols-1',
        hasRightCol && imagesRight ? 'lg:[&>*:first-child]:order-last' : '',
      ]}
    >
      <!-- Text -->
      <div class="m-auto flex max-w-4xl flex-col justify-center" data-animate="animate-fade-in-up">
        {
          title && (
            <h2
              id={`section-${id}-heading`}
              class:list={['font-display mb-6 text-3xl font-bold', highlight ? 'text-white' : 'text-base']}
            >
              {title}
            </h2>
          )
        }
        <div class="prose-content space-y-0 leading-relaxed" set:html={htmlContent} />
      </div>

      <!-- Right column: images and/or map -->
      {
        hasRightCol && (
          <div class="flex flex-col gap-6" data-animate="animate-fade-in-up" data-delay="150ms">
            {map && <LeafletMap lat={map.lat} lng={map.lng} zoom={map.zoom} geojson={map.geojson} label={title} />}
            {hasImages && <ImageBlock images={images} position={imagesRight ? 'right' : 'left'} />}
          </div>
        )
      }
    </div>
  </div>

  {
    separatorAfter && (
      <div class='w-full translate-y-6 rotate-180 text-highlight'>
        <div set:html={separatorContent} class="h-auto w-full" />
      </div>
    )
  }
</section>
