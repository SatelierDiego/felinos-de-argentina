---
import ThreatCard from './ThreatCard.astro';
import type { ThreatGridProps } from '../types/components/threat';

import separatorContent from '../assets/separator.svg?raw';

interface Props extends ThreatGridProps {}

const { threats, separatorBefore = false, separatorAfter = false } = Astro.props;
---

<section class="bg-accent/30 py-20" aria-labelledby="threats-heading">
  {
    separatorBefore && (
      <div class="text-accent/30 w-full overflow-hidden -translate-y-6">
        <div set:html={separatorContent} class="h-auto min-w-[2000px] w-full" />
      </div>
    )
  }
  <div class="mx-auto max-w-7xl px-6">
    <header class="mb-12 text-center">
      <h2 id="threats-heading" class="font-display text-base-900 text-3xl font-bold">Principales amenazas</h2>
      <p class="text-base-500 mx-auto mt-3 max-w-xl text-sm">
        Factores que ponen en riesgo la supervivencia de la especie.
      </p>
    </header>

    <ul class="m-0 grid list-none grid-cols-1 gap-6 p-0 sm:grid-cols-2 lg:grid-cols-4">
      {
        threats.map((threat) => (
          <li class="flex">
            <ThreatCard title={threat.title} icon={threat.icon} description={threat.description} />
          </li>
        ))
      }
    </ul>
  </div>

  {
    separatorAfter && (
      <div class="text-accent/30 w-full overflow-hidden translate-y-6 rotate-180">
        <div set:html={separatorContent} class="h-auto min-w-[2000px] w-full" />
      </div>
    )
  }
</section>
