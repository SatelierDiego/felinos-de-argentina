---
import type { PhotographerRowProps } from '../types/components/PhotographerRow';

interface Props extends PhotographerRowProps {}

const { nombre, contacto = [], felinos = [], felinosByScientificName } = Astro.props;

const sortedFelinos = felinos.slice().sort((a, b) => a.localeCompare(b, 'es'));
---

<li class="flex items-center justify-between gap-6 py-5">
  <div class="flex flex-col gap-0.5">
    <span class="text-base-900 font-medium">{nombre}</span>
    {sortedFelinos.length > 0 && (
      <p class="text-xs tracking-wide text-stone-400">
        {sortedFelinos.map((nombre, i) => {
          const slug = felinosByScientificName.get(nombre.toLowerCase());
          return (
            <>
              {slug ? (
                <a href={`/felinos/${slug}/`} class="transition-colors hover:text-stone-600">
                  {nombre}
                </a>
              ) : (
                <span>{nombre}</span>
              )}
              {i < sortedFelinos.length - 1 && ', '}
            </>
          );
        })}
      </p>
    )}
  </div>
  <div class="flex flex-wrap justify-end gap-2">
    {contacto.map((c) => (
      <a
        href={c.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full bg-stone-100 px-3 py-1.5 text-xs font-semibold text-stone-600 transition-colors duration-150 hover:bg-stone-200"
      >
        {c.titulo}
        <i class="ph ph-arrow-up-right" aria-hidden="true" />
      </a>
    ))}
  </div>
</li>
