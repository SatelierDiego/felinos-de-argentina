---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';

type SizeEntry = {
  weight: string;
  body: string;
  tail: string;
  height_at_withers: string;
};

type StatusEntry = {
  iucn: string;
  sarem: string;
};

interface Stats {
  silouette?: ImageMetadata;
  size: SizeEntry;
  conservationStatus: StatusEntry;
  diet: string;
  habitat: string;
  activity: string;
  habits: string;
  generationTime: string;
  otherNames: string;
}

interface Props {
  scientificName: string;
  commonName: string;
  stats: Stats;
}

const { scientificName, commonName, stats } = Astro.props;

const statusBadge: Record<string, { label: string; color: string }> = {
  EX: {
    label: 'Extinto',
    color: 'bg-black',
  },
  RE: {
    label: 'Extinto a nivel regional',
    color: 'bg-neutral-800',
  },
  CR: {
    label: 'En Peligro Crítico',
    color: 'bg-red-700',
  },
  EN: {
    label: 'En Peligro',
    color: 'bg-red-500',
  },
  VU: {
    label: 'Vulnerable',
    color: 'bg-orange-500',
  },
  NT: {
    label: 'Casi Amenazado',
    color: 'bg-yellow-400',
  },
  LC: {
    label: 'Preocupación Menor',
    color: 'bg-green-500',
  },
  DD: {
    label: 'Datos Insuficientes',
    color: 'bg-gray-400',
  },
  NE: {
    label: 'No Evaluado',
    color: 'bg-gray-300',
  },
  NA: {
    label: 'No Aplicable',
    color: 'bg-gray-200',
  },
};

const status = {
  iucn: statusBadge[stats.conservationStatus.iucn] ?? {
    dot: 'bg-stone-300',
    label: '—',
  },
  sarem: statusBadge[stats.conservationStatus.sarem] ?? {
    dot: 'bg-stone-300',
    label: '—',
  },
};
---

<section class="bg-alternative px-8 py-6 text-stone-100">
  <article class="mx-auto max-w-5xl">
    <h1 class="font-display mb-4 text-xl leading-tight font-bold text-stone-100">
      Ficha del {commonName}
      <span class="text-md font-normal text-stone-300 italic">({scientificName})</span>
    </h1>
    <div class="flex gap-5">
      <div class="flex w-1/4 shrink-0 flex-col gap-4 border-r border-stone-700 pr-6">
        {
          stats.silouette && (
            <Image
              src={stats.silouette}
              alt={'silueta de ' + commonName}
              width={250}
              height={250}
              class="mx-auto mt-10"
              loading="lazy"
            />
          )
        }

        <div class="grid grid-cols-2 gap-x-8 gap-y-4">
          <div>
            <h2 class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Peso</h2>
            <p class="font-display text-sm leading-none text-stone-100">
              {stats.size.weight}
            </p>
          </div>
          <div>
            <h2 class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Alzada</h2>
            <p class="font-display text-sm leading-none text-stone-100">
              {stats.size.height_at_withers}
            </p>
          </div>
          <div>
            <h2 class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Cuerpo</h2>
            <p class="font-display text-sm leading-none text-stone-100">
              {stats.size.body}
            </p>
          </div>
          <div>
            <h2 class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Cola</h2>
            <p class="font-display text-sm leading-none text-stone-100">{stats.size.tail}</p>
          </div>
        </div>
      </div>

      <div class="flex flex-1 flex-col gap-4">
        <div class="flex flex-col gap-2">
          <h2 class="text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Estado de conservación</h2>
          <div class="flex gap-6">
            {
              // iterate status entries
              Object.entries(status).map(([key, { label, color }]) => (
                <div>
                  <h3 class="mb-1 text-sm font-bold tracking-[0.18em] text-stone-400 uppercase">
                    {key === 'sarem' ? 'Argentina' : 'IUCN'}
                  </h3>
                  <div class="mb-0.5 flex items-center gap-1.5">
                    <span class:list={['h-4 w-4 shrink-0 rounded-full border border-stone-500', color]} />
                    <span class="font-display px-2 text-lg leading-none font-bold text-stone-100">
                      {stats.conservationStatus[key as keyof StatusEntry]}
                    </span>
                    <span class="text-sm leading-snug text-stone-300">{label}</span>
                  </div>
                </div>
              ))
            }
          </div>

          <div class="mt-2 flex items-start gap-3">
            <Icon name="bone" class="text-brand mt-0.5 size-6 shrink-0" aria-hidden="true" />
            <div>
              <h2 class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Dieta</h2>
              <p class="text-sm leading-snug text-stone-100">
                {stats.diet}
              </p>
            </div>
          </div>

          <div class="mt-2 flex items-start gap-3">
            <Icon name="map-pin" class="text-accent text-brand mt-0.5 size-6 shrink-0" aria-hidden="true" />
            <div>
              <h2 class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Hábitat</h2>
              <p class="text-sm leading-snug text-stone-100">
                {stats.habitat}
              </p>
            </div>
          </div>

          <div class="mt-2 flex gap-6">
            {
              stats.habits && (
                <div class="flex items-start gap-2">
                  <Icon name="paw" class="text-brand mt-0.5 size-6 shrink-0" aria-hidden="true" />
                  <div>
                    <p class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Hábitos</p>
                    <p class="text-sm leading-snug text-stone-300">{stats.habits}</p>
                  </div>
                </div>
              )
            }
            {
              stats.activity && (
                <div class="flex items-start gap-2">
                  <Icon name="sun-moon" class="text-brand mt-0.5 size-6 shrink-0" aria-hidden="true" />
                  <div>
                    <p class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Actividad</p>
                    <p class="text-sm leading-snug text-stone-300">{stats.activity}</p>
                  </div>
                </div>
              )
            }
            <div class="flex items-start gap-2">
              <Icon name="hourglass" class="text-brand mt-0.5 size-6 shrink-0" aria-hidden="true" />
              <div>
                <p class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Tiempo generacional</p>
                <p class="text-sm leading-snug text-stone-300">{stats.generationTime}</p>
              </div>
            </div>
          </div>
          <div class="mt-2 flex items-start gap-2">
            <Icon name="notebook" class="text-brand mt-0.5 size-6 shrink-0" aria-hidden="true" />
            <div>
              <p class="mb-0.5 text-sm font-bold tracking-[0.18em] text-stone-300 uppercase">Otros nombres</p>
              <p class="text-sm leading-snug text-stone-300">{stats.otherNames}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>
</section>
