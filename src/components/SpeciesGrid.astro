---
import ImageCard from './ImageCard.astro';
import type { SpeciesGridProps } from '../types/components/SpeciesGrid';
import separatorContent from '../assets/separator.svg?raw';

interface Props extends SpeciesGridProps {}

const { felinos, title = 'Los felinos de Argentina', eyebrow = 'Biodiversidad felina' } = Astro.props;
---

<section class="bg-base" aria-labelledby="species-heading">
  <div class="w-full -translate-y-6 text-base">
    <div set:html={separatorContent} class="h-auto w-full" />
  </div>
  <div class="mx-auto max-w-7xl px-6 py-24">
    <div class="mb-14">
      <div>
        <p class="text-background/90 mb-3 text-xs font-bold tracking-[0.18em] uppercase">
          {eyebrow}
        </p>
        <h2
          id="species-heading"
          class="font-display text-background font-bold text-balance"
          style="font-size: var(--text-headline); line-height: var(--text-headline--line-height);"
        >
          {title}
        </h2>
      </div>
    </div>

    <ul class="flex flex-wrap justify-center overflow-hidden" role="list">
      {
        felinos.map((felino, i) => (
          <li class="w-1/2 overflow-hidden p-1.5 sm:w-1/3 lg:w-1/4">
            <ImageCard
              src={felino.image.src}
              alt={felino.image.alt}
              href={`/felinos/${felino.slug}/`}
              aspectRatio="1 / 1"
              widths={[300, 150]}
              sizes="(min-width: 640px) 300, 150"
              overlayTitle={felino.title}
              overlaySubtitle={`<i>${felino.scientific_name}</i>`}
              showArrow
              extraAnchorClass="h-full"
              data-animate="animate-fade-in-up"
              data-delay={`${i * 60}ms`}
            />
          </li>
        ))
      }
      <li
        class="w-1/2 overflow-hidden p-1.5 sm:w-1/3 lg:w-1/4"
        data-animate="animate-fade-in-up"
        data-delay={`${felinos.length * 60}ms`}
      >
        <a
          href="/felinos/"
          class="group rounded-card bg-highlight hover:bg-highlight/90 relative block flex aspect-square items-center justify-center overflow-hidden no-underline transition-colors duration-300"
        >
          <div class="flex flex-col items-center gap-3 text-center">
            <span
              class="text-background/90 max-w-36 text-lg font-semibold tracking-widest uppercase transition-transform duration-500 group-hover:scale-105 motion-reduce:transition-none"
              >Ver todos los felinos</span
            >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="text-background/90 h-5 w-5 transition-transform duration-300 group-hover:translate-x-1"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
        </a>
      </li>
    </ul>
  </div>
</section>
