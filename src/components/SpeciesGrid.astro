---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Felino {
    slug: string;
    title: string;
    scientific_name: string;
    image: {
        src: ImageMetadata;
        alt: string;
    };
}

interface Props {
    felinos: Felino[];
    title?: string;
    eyebrow?: string;
}

const {
    felinos,
    title = "Los felinos de Argentina",
    eyebrow = "Biodiversidad felina",
} = Astro.props;
---

<section class="py-24 bg-white" aria-labelledby="species-heading">
    <div class="mx-auto max-w-7xl px-6">
        <div class="flex items-end justify-between mb-14">
            <div>
                <p
                    class="text-xs font-bold uppercase tracking-[0.18em] text-stone-400 mb-3"
                >
                    {eyebrow}
                </p>
                <h2
                    id="species-heading"
                    class="font-display font-bold text-stone-900 text-balance"
                    style="font-size: var(--text-headline); line-height: var(--text-headline--line-height);"
                >
                    {title}
                </h2>
            </div>
            <a
                href="/felinos/"
                class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold text-stone-500 uppercase tracking-widest hover:text-stone-900 transition-[color] duration-150"
            >
                Ver todos
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>

        <ul class="flex flex-wrap justify-center overflow-hidden" role="list">
            {
                felinos.map((felino, i) => (
                    <li
                        class="w-1/2 sm:w-1/3 lg:w-1/4 bg-white border border-stone-200  overflow-hidden rounded-card"
                        data-animate="animate-fade-in-up"
                        data-delay={`${i * 60}ms`}
                    >
                        <a
                            href={`/felinos/${felino.slug}/`}
                            class="group relative flex flex-col h-full overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-amber-500"
                        >
                            <div class="aspect-square overflow-hidden bg-stone-100">
                                <Image
                                    src={felino.image.src}
                                    alt={felino.image.alt}
                                    width={400}
                                    height={400}
                                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105 motion-reduce:transition-none"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                            <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 motion-reduce:transition-none">
                                <div class="flex items-center justify-between gap-2 p-4 w-full translate-y-3 group-hover:translate-y-0 transition-transform duration-300 motion-reduce:transition-none">
                                    <div class="flex flex-col gap-0.5 min-w-0">
                                        <p class="font-semibold text-white leading-snug truncate">
                                            {felino.title}
                                        </p>
                                        <p class="text-xs italic text-white/70 truncate">
                                            {felino.scientific_name}
                                        </p>
                                    </div>
                                    <i
                                        class="ph ph-arrow-right text-xl text-white shrink-0"
                                        aria-hidden="true"
                                    />
                                </div>
                            </div>
                        </a>
                    </li>
                ))
            }
        </ul>

        <div class="mt-8 sm:hidden">
            <a
                href="/felinos/"
                class="inline-flex items-center gap-2 text-sm font-semibold text-stone-500 uppercase tracking-widest hover:text-stone-900 transition-[color] duration-150"
            >
                Ver todos los felinos
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>
    </div>
</section>
