---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { SpeciesGridProps } from '../types/components/SpeciesGrid';

interface Props extends SpeciesGridProps {}

const { felinos, title = 'Los felinos de Argentina', eyebrow = 'Biodiversidad felina' } = Astro.props;
---

<section class="bg-white py-24" aria-labelledby="species-heading">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-14 flex items-end justify-between">
      <div>
        <p class="mb-3 text-xs font-bold tracking-[0.18em] text-stone-400 uppercase">
          {eyebrow}
        </p>
        <h2
          id="species-heading"
          class="font-display font-bold text-balance text-stone-900"
          style="font-size: var(--text-headline); line-height: var(--text-headline--line-height);"
        >
          {title}
        </h2>
      </div>
      <a
        href="/felinos/"
        class="hidden items-center gap-2 text-sm font-semibold tracking-widest text-stone-500 uppercase transition-[color] duration-150 hover:text-stone-900 sm:inline-flex"
      >
        Ver todos
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
    </div>

    <ul class="flex flex-wrap justify-center overflow-hidden" role="list">
      {
        felinos.map((felino, i) => (
          <li
            class="rounded-card w-1/2 overflow-hidden border border-stone-200 bg-white sm:w-1/3 lg:w-1/4"
            data-animate="animate-fade-in-up"
            data-delay={`${i * 60}ms`}
          >
            <a
              href={`/felinos/${felino.slug}/`}
              class="group relative flex h-full flex-col overflow-hidden focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:outline-none focus-visible:ring-inset"
            >
              <div class="aspect-square overflow-hidden bg-stone-100">
                <Image
                  src={felino.image.src}
                  alt={felino.image.alt}
                  width={500}
                  height={500}
                  sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105 motion-reduce:transition-none"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100 motion-reduce:transition-none">
                <div class="flex w-full translate-y-3 items-center justify-between gap-2 p-4 transition-transform duration-300 group-hover:translate-y-0 motion-reduce:transition-none">
                  <div class="flex min-w-0 flex-col gap-0.5">
                    <p class="truncate leading-snug font-semibold text-white">{felino.title}</p>
                    <p class="truncate text-xs text-white/70 italic">{felino.scientific_name}</p>
                  </div>
                  <i class="ph ph-arrow-right shrink-0 text-xl text-white" aria-hidden="true" />
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mt-8 sm:hidden">
      <a
        href="/felinos/"
        class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest text-stone-500 uppercase transition-[color] duration-150 hover:text-stone-900"
      >
        Ver todos los felinos
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
